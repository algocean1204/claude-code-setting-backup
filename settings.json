{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["ClaudeTalkToFigma"],
  "enabledPlugins": {
    "github@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "firebase@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "code-review@claude-code-plugins": true,
    "plugin-dev@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "plugin-dev@claude-plugins-official": true,
    "modular-architecture-design@local": true
  },
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_TOOL_ARG_FILE_PATH\"; if echo \"$file\" | grep -q '.claude/rules/'; then echo \"[$(date '+%Y-%m-%d %H:%M')] $(basename \"$file\") — modified\" >> ~/.claude/rules/CHANGELOG.md; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "any-buddy apply --silent"
          }
        ]
      }
    ]
  }
}
